<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>スマホスタイル診断</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Shippori+Mincho:wght@400;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0c0a;
    --surface: #211e1a;
    --gold: #d4b070;
    --gold-light: #ecd490;
    --cream: #faf3e8;
    --muted: #a09488;
    --accent-a: #8b6f4e;
    --accent-b: #4a6b7a;
    --text: #f0e6d8;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
background: #0e0c0a !important;
}

body {
color: var(–text);
font-family: ‘Noto Serif JP’, serif;
min-height: 100vh;
overflow-x: hidden;
}

#screen-q {
background: #0e0c0a;
}

/* Grain overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 200 200’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.04’/%3E%3C/svg%3E”);
pointer-events: none;
z-index: 100;
opacity: 0.6;
}

.screen {
display: none;
min-height: 100vh;
background: #0e0c0a;
animation: fadeIn 0.6s ease forwards;
}
.screen.active { display: flex; }

@keyframes fadeIn {
from { opacity: 0; transform: translateY(16px); }
to { opacity: 1; transform: translateY(0); }
}

/* ===== TOP SCREEN ===== */
#screen-top {
flex-direction: column;
align-items: center;
justify-content: center;
padding: 40px 24px;
text-align: center;
position: relative;
}

.top-deco {
position: absolute;
top: 0; left: 0; right: 0; bottom: 0;
overflow: hidden;
pointer-events: none;
}
.top-deco::before {
content: ‘’;
position: absolute;
top: -120px; right: -80px;
width: 400px; height: 400px;
border-radius: 50%;
background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
}
.top-deco::after {
content: ‘’;
position: absolute;
bottom: -100px; left: -60px;
width: 300px; height: 300px;
border-radius: 50%;
background: radial-gradient(circle, rgba(74,107,122,0.1) 0%, transparent 70%);
}

.eyebrow {
font-family: ‘DM Serif Display’, serif;
font-size: 11px;
letter-spacing: 0.3em;
color: var(–gold);
text-transform: uppercase;
margin-bottom: 20px;
}

.top-title {
font-family: ‘Shippori Mincho’, serif;
font-size: clamp(32px, 8vw, 52px);
font-weight: 600;
line-height: 1.2;
margin-bottom: 12px;
background: linear-gradient(135deg, var(–cream) 0%, var(–gold-light) 50%, var(–cream) 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}

.top-sub {
font-size: 14px;
color: #c0b4a6;
line-height: 1.8;
margin-bottom: 40px;
max-width: 300px;
}

.product-preview {
display: flex;
gap: 20px;
margin-bottom: 48px;
align-items: center;
}

.product-card-mini {
background: var(–surface);
border: 1px solid rgba(201,169,110,0.2);
border-radius: 16px;
padding: 20px 16px;
width: 130px;
text-align: center;
position: relative;
overflow: hidden;
}
.product-card-mini::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: linear-gradient(90deg, transparent, var(–gold), transparent);
}

.product-emoji { font-size: 36px; margin-bottom: 8px; }
.product-label {
font-size: 11px;
color: var(–gold);
letter-spacing: 0.1em;
}

.vs-badge {
font-family: ‘DM Serif Display’, serif;
font-style: italic;
font-size: 20px;
color: var(–muted);
}

.btn-start {
background: linear-gradient(135deg, var(–gold) 0%, var(–gold-light) 100%);
color: var(–bg);
border: none;
padding: 16px 48px;
font-family: ‘Shippori Mincho’, serif;
font-size: 16px;
font-weight: 600;
border-radius: 50px;
cursor: pointer;
letter-spacing: 0.1em;
position: relative;
overflow: hidden;
transition: transform 0.2s, box-shadow 0.2s;
box-shadow: 0 8px 32px rgba(201,169,110,0.3);
}
.btn-start:hover {
transform: translateY(-2px);
box-shadow: 0 12px 40px rgba(201,169,110,0.4);
}
.btn-start:active { transform: translateY(0); }

.q-count-note {
margin-top: 16px;
font-size: 11px;
color: var(–muted);
letter-spacing: 0.1em;
}

/* ===== QUESTION SCREEN ===== */
#screen-q {
flex-direction: column;
padding: 0;
}

.q-header {
padding: 32px 24px 0;
position: relative;
}

.progress-bar-wrap {
height: 3px;
background: rgba(255,255,255,0.06);
border-radius: 2px;
margin-bottom: 24px;
overflow: hidden;
}
.progress-bar-fill {
height: 100%;
background: linear-gradient(90deg, var(–gold), var(–gold-light));
border-radius: 2px;
transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
}

.q-meta {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 32px;
}

.q-num {
font-family: ‘DM Serif Display’, serif;
font-style: italic;
color: var(–gold);
font-size: 13px;
letter-spacing: 0.1em;
}

.q-step-dots {
display: flex;
gap: 6px;
}
.dot {
width: 6px; height: 6px;
border-radius: 50%;
background: rgba(255,255,255,0.1);
transition: background 0.3s;
}
.dot.done { background: var(–gold); }
.dot.current { background: var(–gold-light); box-shadow: 0 0 8px var(–gold); }

.q-body {
flex: 1;
padding: 0 24px 32px;
display: flex;
flex-direction: column;
}

.q-scenario {
font-size: 11px;
color: var(–muted);
letter-spacing: 0.15em;
text-transform: uppercase;
margin-bottom: 12px;
}

.q-text {
font-family: ‘Shippori Mincho’, serif;
font-size: clamp(20px, 5vw, 28px);
font-weight: 600;
line-height: 1.5;
margin-bottom: 8px;
color: #1a1714;
}

.q-hint {
font-size: 13px;
color: #b0a498;
margin-bottom: 36px;
line-height: 1.7;
}

.choices {
display: flex;
flex-direction: column;
gap: 14px;
flex: 1;
}

.choice-btn {
background: var(–surface);
border: 1px solid rgba(255,255,255,0.08);
border-radius: 16px;
padding: 20px;
cursor: pointer;
text-align: left;
transition: all 0.25s ease;
position: relative;
overflow: hidden;
display: flex;
align-items: flex-start;
gap: 14px;
}
.choice-btn::before {
content: ‘’;
position: absolute;
inset: 0;
opacity: 0;
transition: opacity 0.25s;
}
.choice-btn:nth-child(1)::before {
background: linear-gradient(135deg, rgba(139,111,78,0.15), transparent);
}
.choice-btn:nth-child(2)::before {
background: linear-gradient(135deg, rgba(74,107,122,0.15), transparent);
}
.choice-btn:hover::before { opacity: 1; }
.choice-btn:hover {
border-color: rgba(201,169,110,0.3);
transform: translateX(4px);
}

.choice-icon {
font-size: 28px;
flex-shrink: 0;
line-height: 1;
}

.choice-text-wrap {}
.choice-main {
font-family: ‘Shippori Mincho’, serif;
font-size: 15px;
font-weight: 600;
color: var(–cream);
margin-bottom: 4px;
line-height: 1.4;
}
.choice-sub {
font-size: 13px;
color: #b0a498;
line-height: 1.5;
}

/* ===== RESULT SCREEN ===== */
#screen-result {
flex-direction: column;
padding: 0;
}

.result-hero {
padding: 48px 24px 32px;
text-align: center;
position: relative;
overflow: hidden;
}

.result-hero-glow {
position: absolute;
top: -40px; left: 50%; transform: translateX(-50%);
width: 280px; height: 280px;
border-radius: 50%;
pointer-events: none;
}

.result-badge {
display: inline-block;
font-size: 11px;
letter-spacing: 0.25em;
color: var(–gold);
border: 1px solid rgba(201,169,110,0.4);
border-radius: 50px;
padding: 6px 20px;
margin-bottom: 24px;
text-transform: uppercase;
}

.result-product-icon {
font-size: 80px;
display: block;
margin: 0 auto 20px;
animation: floatIcon 3s ease-in-out infinite;
}
@keyframes floatIcon {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-8px); }
}

.result-type {
font-family: ‘Shippori Mincho’, serif;
font-size: clamp(28px, 7vw, 40px);
font-weight: 600;
line-height: 1.2;
margin-bottom: 8px;
}

.result-tagline {
font-family: ‘DM Serif Display’, serif;
font-style: italic;
font-size: 15px;
color: var(–gold);
margin-bottom: 24px;
}

.result-body {
padding: 0 24px 40px;
}

.result-desc {
background: var(–surface);
border-radius: 20px;
padding: 24px;
margin-bottom: 20px;
border: 1px solid rgba(255,255,255,0.08);
font-size: 14px;
line-height: 2;
color: #e8ddd0;
}

.result-points {
margin-bottom: 24px;
}

.result-points-title {
font-size: 11px;
letter-spacing: 0.2em;
color: var(–gold);
text-transform: uppercase;
margin-bottom: 14px;
}

.point-item {
display: flex;
align-items: flex-start;
gap: 12px;
padding: 14px 0;
border-bottom: 1px solid rgba(255,255,255,0.05);
}
.point-item:last-child { border-bottom: none; }

.point-dot {
width: 8px; height: 8px;
border-radius: 50%;
background: var(–gold);
flex-shrink: 0;
margin-top: 6px;
}

.point-text {
font-size: 14px;
line-height: 1.7;
color: #e8ddd0;
}

.cta-section {
background: linear-gradient(135deg, rgba(201,169,110,0.12), rgba(201,169,110,0.04));
border: 1px solid rgba(201,169,110,0.25);
border-radius: 20px;
padding: 24px;
margin-bottom: 20px;
text-align: center;
}

.cta-label {
font-size: 11px;
color: var(–gold);
letter-spacing: 0.2em;
text-transform: uppercase;
margin-bottom: 8px;
}

.cta-text {
font-family: ‘Shippori Mincho’, serif;
font-size: 18px;
font-weight: 600;
color: var(–cream);
margin-bottom: 16px;
line-height: 1.5;
}

.btn-cta {
background: linear-gradient(135deg, var(–gold) 0%, var(–gold-light) 100%);
color: var(–bg);
border: none;
padding: 14px 36px;
font-family: ‘Shippori Mincho’, serif;
font-size: 15px;
font-weight: 600;
border-radius: 50px;
cursor: pointer;
width: 100%;
transition: all 0.2s;
box-shadow: 0 6px 24px rgba(201,169,110,0.3);
letter-spacing: 0.05em;
}
.btn-cta:hover {
transform: translateY(-2px);
box-shadow: 0 10px 32px rgba(201,169,110,0.4);
}

.btn-retry {
background: transparent;
border: 1px solid rgba(255,255,255,0.15);
color: var(–muted);
padding: 12px;
border-radius: 50px;
cursor: pointer;
width: 100%;
font-family: ‘Noto Serif JP’, serif;
font-size: 13px;
transition: all 0.2s;
margin-top: 12px;
}
.btn-retry:hover {
border-color: rgba(255,255,255,0.3);
color: var(–text);
}

/* Score bar */
.score-bar-section {
margin-bottom: 24px;
}
.score-bar-labels {
display: flex;
justify-content: space-between;
font-size: 12px;
color: #b0a498;
margin-bottom: 8px;
letter-spacing: 0.05em;
}
.score-bar-track {
height: 8px;
background: rgba(255,255,255,0.06);
border-radius: 50px;
overflow: hidden;
position: relative;
}
.score-bar-fill-a {
position: absolute;
left: 0; top: 0; bottom: 0;
background: linear-gradient(90deg, var(–accent-a), #c9a96e);
border-radius: 50px;
transition: width 1s cubic-bezier(0.4,0,0.2,1) 0.3s;
}
.score-bar-fill-b {
position: absolute;
right: 0; top: 0; bottom: 0;
background: linear-gradient(270deg, var(–accent-b), #4a9bb5);
border-radius: 50px;
transition: width 1s cubic-bezier(0.4,0,0.2,1) 0.3s;
}
</style>

</head>
<body>

<!-- TOP -->

<div id="screen-top" class="screen active">
  <div class="top-deco"></div>
  <div class="eyebrow">Style Diagnosis</div>
  <h1 class="top-title">あなたに合う<br>スマホスタイルは？</h1>
  <p class="top-sub">持ち方・ライフスタイル・こだわりから<br>あなたにぴったりのスタイルを診断します</p>

  <div class="product-preview">
    <div class="product-card-mini">
      <div class="product-emoji">🤌</div>
      <div class="product-label">ハンドストラップ</div>
    </div>
    <div class="vs-badge">vs</div>
    <div class="product-card-mini">
      <div class="product-emoji">👜</div>
      <div class="product-label">ショルダー</div>
    </div>
  </div>

<button class="btn-start" onclick="startQuiz()">診断スタート</button>

  <p class="q-count-note">全 6 問 ・ 約 1 分</p>
</div>

<!-- QUESTION -->

<div id="screen-q" class="screen">
  <div class="q-header">
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="progress-fill"></div>
    </div>
    <div class="q-meta">
      <span class="q-num" id="q-num-label">Question 1</span>
      <div class="q-step-dots" id="step-dots"></div>
    </div>
  </div>
  <div class="q-body">
    <div class="q-scenario" id="q-scenario"></div>
    <div class="q-text" id="q-text"></div>
    <div class="q-hint" id="q-hint"></div>
    <div class="choices" id="choices"></div>
  </div>
</div>

<!-- RESULT -->

<div id="screen-result" class="screen">
  <div class="result-hero">
    <div class="result-hero-glow" id="result-glow"></div>
    <div class="result-badge">Your Style</div>
    <span class="result-product-icon" id="result-icon"></span>
    <div class="result-type" id="result-type"></div>
    <div class="result-tagline" id="result-tagline"></div>
  </div>

  <div class="result-body">
    <div class="score-bar-section">
      <div class="score-bar-labels">
        <span>🤌 ハンドストラップ</span>
        <span>ショルダー 👜</span>
      </div>
      <div class="score-bar-track">
        <div class="score-bar-fill-a" id="bar-a"></div>
        <div class="score-bar-fill-b" id="bar-b"></div>
      </div>
    </div>

```
<div class="result-desc" id="result-desc"></div>

<div class="result-points">
  <div class="result-points-title">あなたが重視するポイント</div>
  <div id="result-points-list"></div>
</div>

<div class="cta-section">
  <div class="cta-label">おすすめ</div>
  <div class="cta-text" id="cta-text"></div>
  <button class="btn-cta" id="cta-btn">商品を見てみる →</button>
</div>

<button class="btn-retry" onclick="restartQuiz()">もう一度診断する</button>
```

  </div>
</div>

<script>
const questions = [
  {
    scenario: "Scene 01 ／ 外出シーン",
    text: "外出するとき、スマホはどこに入れることが多い？",
    hint: "普段の持ち歩き方を想像してみてください",
    choices: [
      { icon: "👖", main: "ポケットに入れる", sub: "すぐ取り出せる手軽さが好き", score: "A" },
      { icon: "🎒", main: "バッグやポーチに入れる", sub: "落下やキズが心配、丁寧に扱いたい", score: "B" }
    ]
  },
  {
    scenario: "Scene 02 ／ 使用スタイル",
    text: "スマホを使うとき、どんなシーンが多い？",
    hint: "使い方のクセをチェックしてみましょう",
    choices: [
      { icon: "🚶", main: "歩きながら・立ちながら操作", sub: "移動中にサッと使う場面が多い", score: "A" },
      { icon: "☕", main: "座ってゆっくり使う", sub: "カフェや電車でじっくり見ることが多い", score: "B" }
    ]
  },
  {
    scenario: "Scene 03 ／ ファッション",
    text: "コーデのこだわりは？",
    hint: "普段の服装やスタイルから考えてみて",
    choices: [
      { icon: "🧢", main: "シンプル＆機能的なコーデが好き", sub: "動きやすさ・使いやすさを優先したい", score: "A" },
      { icon: "✨", main: "アクセやバッグでおしゃれを楽しみたい", sub: "トータルコーデにこだわりがある", score: "B" }
    ]
  },
  {
    scenario: "Scene 04 ／ 手ぶらへの意識",
    text: "理想の外出スタイルは？",
    hint: "日常のシーンを思い浮かべながらどうぞ",
    choices: [
      { icon: "🤲", main: "できるだけ身軽・手ぶらでいたい", sub: "余計な荷物は持ちたくない派", score: "A" },
      { icon: "💼", main: "必要なものはまとめて持ち歩く", sub: "安心のためにバッグを持つのが基本", score: "B" }
    ]
  },
  {
    scenario: "Scene 05 ／ 決め手",
    text: "スマホアクセに求める一番の価値は？",
    hint: "あなたのこだわりが見えてくるかも",
    choices: [
      { icon: "🛡️", main: "落下・紛失防止などの実用性", sub: "安心感と使いやすさが最優先", score: "A" },
      { icon: "🪞", main: "見た目のかわいさ・おしゃれさ", sub: "持つたびにテンションが上がるものがいい", score: "B" }
    ]
  },
  {
    scenario: "Scene 06 ／ シーン別",
    text: "週末の過ごし方で近いのは？",
    hint: "ライフスタイル全体から探ってみましょう",
    choices: [
      { icon: "🏃", main: "アクティブ！カフェ・散歩・イベント巡り", sub: "外出が多く、動き回ることが多い", score: "A" },
      { icon: "🛍️", main: "ショッピングやお出かけを楽しむ", sub: "おしゃれしてゆっくり過ごしたい", score: "B" }
    ]
  }
];

const results = {
  A: {
    icon: "🤌",
    type: "ハンドストラップ派",
    tagline: "「手放さない」スマートライフスタイル",
    glow: "rgba(139,111,78,0.15)",
    desc: "アクティブに動き回るあなたには、ハンドストラップがぴったり。ポケットに入れたまま指を通すだけで落下防止になり、片手操作もラクラク。身軽さを保ちながらスマホをしっかりホールドできるのが最大の魅力です。",
    points: [
      "片手でしっかりホールド、落下・紛失リスクを大幅に軽減",
      "ポケットに入れたままでも使えるシームレスな使い心地",
      "バッグを持たない日も安心、真の手ぶらスタイルを実現",
      "シンプルなデザインでどんなコーデにも自然になじむ"
    ],
    ctaText: "落下防止＆使いやすさを両立した\nハンドストラップを見てみる",
    ctaUrl: "#handstrap"
  },
  B: {
    icon: "👜",
    type: "スマホショルダー派",
    tagline: "「見せる」おしゃれスマホスタイル",
    glow: "rgba(74,107,122,0.15)",
    desc: "コーデにこだわり、丁寧に暮らすあなたにはスマホショルダーが最高のパートナー。スマホをそのままアクセサリーとして持ち歩けるから、バッグの中をごそごそする手間もなし。ファッションの一部として楽しめます。",
    points: [
      "スマホをアクセサリーとしてコーデに取り込めるおしゃれ感",
      "取り出し・しまう動作がなくなりストレスフリー",
      "カード・イヤホンなど小物もまとめてスマートに持ち歩ける",
      "両手が自由になるから撮影やお買い物もよりスムーズ"
    ],
    ctaText: "ファッションに溶け込む\nスマホショルダーを見てみる",
    ctaUrl: "#shoulder"
  }
};

let currentQ = 0;
let scores = { A: 0, B: 0 };

function startQuiz() {
  currentQ = 0;
  scores = { A: 0, B: 0 };
  showScreen('screen-q');
  renderQuestion();
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function renderQuestion() {
  const q = questions[currentQ];
  const total = questions.length;

  document.getElementById('progress-fill').style.width = ((currentQ / total) * 100) + '%';
  document.getElementById('q-num-label').textContent = `Question ${currentQ + 1}`;
  document.getElementById('q-scenario').textContent = q.scenario;
  document.getElementById('q-text').textContent = q.text;
  document.getElementById('q-hint').textContent = q.hint;

  // Dots
  const dots = document.getElementById('step-dots');
  dots.innerHTML = '';
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'dot' + (i < currentQ ? ' done' : i === currentQ ? ' current' : '');
    dots.appendChild(d);
  }

  // Choices
  const choicesEl = document.getElementById('choices');
  choicesEl.innerHTML = '';
  q.choices.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.innerHTML = `
      <span class="choice-icon">${c.icon}</span>
      <div class="choice-text-wrap">
        <div class="choice-main">${c.main}</div>
        <div class="choice-sub">${c.sub}</div>
      </div>`;
    btn.onclick = () => answer(c.score);
    choicesEl.appendChild(btn);
  });
}

function answer(score) {
  scores[score]++;
  currentQ++;
  if (currentQ >= questions.length) {
    showResult();
  } else {
    renderQuestion();
  }
}

function showResult() {
  const winner = scores.A >= scores.B ? 'A' : 'B';
  const r = results[winner];
  const total = questions.length;

  document.getElementById('result-icon').textContent = r.icon;
  document.getElementById('result-type').textContent = r.type;
  document.getElementById('result-tagline').textContent = r.tagline;
  document.getElementById('result-desc').textContent = r.desc;
  document.getElementById('result-glow').style.background = `radial-gradient(circle, ${r.glow} 0%, transparent 70%)`;

  const pct_a = Math.round((scores.A / total) * 100);
  const pct_b = 100 - pct_a;
  setTimeout(() => {
    document.getElementById('bar-a').style.width = pct_a + '%';
    document.getElementById('bar-b').style.width = pct_b + '%';
  }, 200);

  const list = document.getElementById('result-points-list');
  list.innerHTML = '';
  r.points.forEach(p => {
    list.innerHTML += `<div class="point-item"><div class="point-dot"></div><div class="point-text">${p}</div></div>`;
  });

  document.getElementById('cta-text').textContent = r.ctaText;
  document.getElementById('cta-btn').onclick = () => {
    location.href = 'https://mitte2025.theshop.jp/';
  };

  showScreen('screen-result');
}

function restartQuiz() {
  showScreen('screen-top');
}
</script>

</body>
</html>
