fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “13px”, color: MID,
lineHeight: 2.1, fontWeight: 300,
},
pointsBox: {
border: “1px solid”,
padding: “28px”,
display: “flex”, flexDirection: “column”, gap: “14px”,
},
ptHeader: { display: “flex”, alignItems: “center”, gap: “10px”, marginBottom: “4px” },
ptDot: { width: “6px”, height: “6px”, borderRadius: “50%”, flexShrink: 0 },
ptTitle: {
fontFamily: “‘Montserrat’, sans-serif”,
fontSize: “9px”, letterSpacing: “4px”,
color: MID, fontWeight: 600, textTransform: “uppercase”,
},
ptRow: { display: “flex”, alignItems: “baseline”, gap: “14px” },
ptNum: {
fontFamily: “‘Cormorant Garamond’, serif”,
fontSize: “13px”, fontWeight: 400,
flexShrink: 0, letterSpacing: “1px”,
},
ptText: {
fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “13px”, color: DARK,
lineHeight: 1.7, fontWeight: 300,
},
cautionRow: { display: “flex”, alignItems: “flex-start”, gap: “12px”, padding: “0 2px” },
cautionTxt: {
fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “12px”, color: MID,
lineHeight: 1.9, fontWeight: 300,
},
retryBtn: {
background: “transparent”, border: “none”,
cursor: “pointer”,
fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “11px”, color: MID,
letterSpacing: “3px”,
textDecoration: “underline”,
textDecorationColor: “#C0B8AE”,
textUnderlineOffset: “4px”,
padding: “8px 0”, fontWeight: 300,
alignSelf: “center”,
},
};
