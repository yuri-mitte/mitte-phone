color: DARK, lineHeight: 1.85,
},
optCol: { display: “flex”, flexDirection: “column”, gap: “10px” },
optBtn: {
background: “#FAFAF8”, border: “1px solid #EDE8DF”,
padding: “20px 22px”, cursor: “pointer”,
display: “flex”, alignItems: “center”, gap: “18px”,
textAlign: “left”, transition: “all 0.22s ease”, position: “relative”,
width: “100%”,
},
optOn: { background: DARK, borderColor: DARK },
optNum: {
fontFamily: “‘Cormorant Garamond’, serif”,
fontSize: “11px”, color: “#C0B8AE”,
letterSpacing: “2px”, flexShrink: 0, fontWeight: 400,
},
optNumOn: { color: GOLD },
optLabel: {
fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “14px”, lineHeight: 1.6, fontWeight: 300, flex: 1,
},
check: { color: GOLD, fontSize: “14px”, flexShrink: 0 },
nextBtn: {
background: “transparent”,
border: `1px solid ${DARK}`,
padding: “16px 28px”, cursor: “pointer”,
fontFamily: “‘Noto Serif JP’, serif”,
fontSize: “12px”, color: DARK,
letterSpacing: “4px”, fontWeight: 300,
transition: “all 0.2s”, width: “100%”,
},
